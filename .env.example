# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Required: Long random string for session signing.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# Optional: Override database path (useful for cloud with a persistent volume).
# Example on Render: /var/data/garage.db
# GARAGE_DATABASE=/var/data/garage.db

# Optional: Override the base data directory (backups, logs).
# Example on Render: /var/data
# DATA_DIR=/var/data

# Optional: Set to "1" only during local development.
# FLASK_DEBUG=0

# Admin email OTP login is temporarily disabled in routes.
# ADMIN_OTP_EMAIL is the default mailbox that receives admin login OTPs.
ADMIN_OTP_EMAIL=replace-with-admin-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=1
SMTP_USERNAME=replace-with-smtp-username
SMTP_PASSWORD=replace-with-smtp-app-password
SMTP_FROM_EMAIL=replace-with-sender-email@example.com
